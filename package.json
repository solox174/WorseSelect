{
  "name": "worse-select",
  "version": "0.5.1",
  "description": "Native-first, dependency-free custom selects with search, multi-select, and zero framework lock-in.",
  "keywords": [
    "select",
    "dropdown",
    "custom-select",
    "listbox",
    "multiselect",
    "searchable-select",
    "native-select",
    "progressive-enhancement",
    "html-select",
    "typescript"
  ],
  "homepage": "https://github.com/solox174/WorseSelect#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solox174/WorseSelect.git"
  },
  "bugs": {
    "url": "https://github.com/solox174/WorseSelect/issues"
  },
  "license": "LGPL-3.0-or-later",
  "author": "Kevin Matthews",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --out-dir dist --sourcemap inline",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --out-dir dist --minify",
    "demo": "npm run build && cp dist/index.js docs/dist/index.js",
    "prepublishOnly": "npm run build",
    "test": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "serve": "^14.2.6",
    "tsup": "^8.0.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
