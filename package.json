{
  "name": "worse-select",
  "version": "0.1.0",
  "description": "Native-first, dependency-free custom selects with search, multi-select, and zero framework lock-in.",
  "keywords": [
    "select",
    "dropdown",
    "custom-select",
    "listbox",
    "multiselect",
    "searchable-select",
    "native-select",
    "progressive-enhancement",
    "html-select",
    "typescript"
  ],
  "homepage": "https://github.com/solox174/WorseSelect#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solox174/WorseSelect.git"
  },
  "bugs": {
    "url": "https://github.com/solox174/WorseSelect/issues"
  },
  "license": "AGPL-3.0-or-later",
  "author": "Kevin Matthews",
  "type": "module",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --out-dir dist --sourcemap inline",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --out-dir dist",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}